---
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

const MAX_WIDTH = 1080;
const modules = import.meta.glob<{ default: ImageMetadata }>('../../assets/ba-exhibition-2026/*.{jpg,JPG,png}', { eager: true });

const imgs: Record<string, string> = {};
for (const [path, mod] of Object.entries(modules)) {
    const name = path.split('/').pop() as string;
    const src = mod.default;
    // QR code stays a lossless PNG; photos become width-capped WebP
    const optimized = name.endsWith('.png')
        ? await getImage({ src, format: 'png' })
        : await getImage({ src, format: 'webp', quality: 80, width: Math.min(MAX_WIDTH, src.width) });
    imgs[name] = optimized.src;
}
---
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, minimum-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>British Academy Ideas Festival</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Lora:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
<style is:inline>
  :root {
    --cream:    #f5f0e8;
    --sand:     #dde8e6;
    --terracotta: #b06a2a;
    --rust:     #8a5020;
    --ochre:    #ebb978;
    --brown:    #2e4a4a;
    --charcoal: #1e3c3a;
    --overlay:  rgba(18,38,36,0.78);
    --caption-bg: rgba(245,240,232,0.97);
  }

  * { margin:0; padding:0; box-sizing:border-box; }

  /* Character transition slides on black background */
  .slide-char-transition .slide-tag { color: var(--terracotta); }
  .slide-char-transition .slide-headline { color: #1a1a1a; }
  .slide-char-transition .slide-body { color: #2c2c2c; }
  .slide-char-transition .ornament { background: var(--terracotta); }
  .slide-char-transition .char-name { color: #1a1a1a; }
  .slide-char-transition .char-role { color: var(--rust); }

  html, body {
    width:100%; height:100%;
    background: var(--charcoal);
    overflow: hidden;
    font-family: 'Lora', Georgia, serif;
    color: var(--charcoal);
    cursor: default;
    font-size: clamp(10px, 1.8vmin, 22px); /* Fluid base: vmin scales on both phones and large screens */
  }

  /* ── SLIDE CONTAINER ── */
  #slideshow {
    width:100vw; height:100vh;
    position:relative;
  }

  .slide {
    position:absolute; inset:0;
    opacity:0;
    transition: opacity 0.9s ease;
    pointer-events:none;
  }
  .slide.active {
    opacity:1;
    pointer-events:all;
  }

  /* ── SLIDE TYPES ── */

  /* Title */
  .slide-title {
    background: var(--charcoal);
    display:flex; flex-direction:column;
    align-items:center; justify-content:center;
    text-align:center;
    padding: 40px 80px;
  }
  .slide-title .eyebrow {
    font-family:'Lora', serif;
    font-size: clamp(1rem,1.4vw,1.6rem);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ochre);
    margin-bottom: 3vmin;
  }
  .slide-title h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(3.8rem, 8vw, 7.5rem);
    line-height: 1.12;
    color: var(--cream);
    max-width: 1200px;
    margin-bottom: 3vmin;
  }
  .slide-title h1 em {
    color: var(--ochre);
    font-style: italic;
  }
  .slide-title .subtitle {
    font-size: clamp(1.2rem,1.8vw,2rem);
    color: var(--sand);
    letter-spacing: 0.08em;
    opacity: 0.85;
  }
  .title-ornament {
    width: 80px; height: 3px;
    background: var(--terracotta);
    margin: 2.5vmin auto;
  }

  /* Image-only slides (maps, frames) */
  .slide-image {
    background: var(--charcoal);
    display:flex; align-items:center; justify-content:center;
  }
  .slide-image img {
    max-width:100%; max-height:100%;
    object-fit:contain;
    display:block;
  }

  /* Text + image split */
  .slide-split {
    display:grid;
    grid-template-columns: 1fr 1fr;
    background: var(--cream);
  }
  .slide-split .left {
    display:flex; flex-direction:column;
    justify-content:center;
    padding: 5vmin 4vmin;
    background: var(--cream);
  }
  .slide-split .right {
    position:relative;
    overflow:hidden;
  }
  .slide-split .right img {
    width:100%; height:100%;
    object-fit:cover;
  }

  /* Text-only / transition slides */
  .slide-text {
    background: var(--sand);
    display:flex; flex-direction:column;
    align-items:center; justify-content:center;
    padding: 4vmin 7vmin;
    text-align:center;
    overflow:hidden;
  }

  /* Placeholder for missing images */
  .img-placeholder {
    width:100%; height:100%;
    background: linear-gradient(135deg, #c8d8d6 0%, #8aada8 100%);
    display:flex; flex-direction:column;
    align-items:center; justify-content:center;
    gap: 1.2vmin;
    color: var(--brown);
  }
  .img-placeholder .ph-icon {
    font-size: clamp(1.8rem,2.5vw,3rem);
    opacity: 0.5;
  }
  .img-placeholder .ph-label {
    font-family: 'Lora', serif;
    font-size: clamp(0.7rem,0.8vw,0.9rem);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.7;
    max-width: 240px;
    text-align:center;
    line-height:1.5;
  }

  /* Comic frame slides */
  /* ── COMIC FRAME SLIDES — stacked layout ── */
  .slide-frame {
    background: #000;
    display:flex;
    flex-direction:column;
    overflow:hidden;
  }
  /* sentence bar at top — fixed height so image area is constant */
  .frame-label {
    flex: 0 0 9vmin;
    display:flex; align-items:center; justify-content:center;
    background: #000;
    overflow: hidden;
  }
  .frame-label .frame-sentence {
    font-family:'Playfair Display', serif;
    font-size: clamp(0.75rem, 1.3vw, 1.35rem);
    color: var(--cream);
    text-align:center;
    line-height: 1.4;
    width: 100%;
    padding: 1.5vmin 5vmin;
    box-sizing: border-box;
    border-bottom: 0.2vmin solid rgba(245,240,232,0.12);
  }
  /* image fills middle, contained (gaps on sides are fine) */
  .slide-frame img.framed {
    flex: 1 1 0;
    min-height: 0;
    width: 100%;
    object-fit: contain;
    display: block;
    background: #000;
  }
  .slide-frame .img-placeholder {
    flex: 1 1 0;
    min-height: 0;
    display:flex; align-items:center; justify-content:center;
    background: #000;
  }

  /* ── STAT BAR — fixed height so image area is constant ── */
  .stat-bar {
    flex: 0 0 12vmin;
    display:flex; flex-direction:column; justify-content:center; gap:0.4vmin;
    background: #000;
    border-top: 0.35vmin solid var(--terracotta);
    padding: 1.2vmin 5vmin;
    overflow: hidden;
    z-index: 30;
  }
  .stat-label {
    font-family:'Lora', serif;
    font-size: clamp(0.6rem, 0.75vw, 0.85rem);
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ochre);
    flex-shrink: 0;
  }
  .stat-text {
    font-family:'Playfair Display', serif;
    font-size: clamp(0.7rem, 1.05vw, 1.1rem);
    line-height: 1.45;
    color: var(--cream);
  }
  /* ── TYPOGRAPHY helpers ── */
  .slide-tag {
    font-size:clamp(0.9rem,1.3vw,1.6rem);
    letter-spacing:0.2em;
    text-transform:uppercase;
    color: var(--terracotta);
    margin-bottom:1.5vmin;
    font-family:'Lora', serif;
  }
  .slide-headline {
    font-family:'Playfair Display', serif;
    font-size: clamp(3rem, 5vw, 4rem);
    line-height:1.18;
    color: var(--charcoal);
    margin-bottom:2vmin;
  }
  .slide-headline.light { color: var(--cream); }
  .slide-body {
    font-family:'Lora', serif;
    font-size: clamp(1.2rem, 1.8vw, 1.6rem);
    line-height:1.75;
    color: var(--brown);
  }
  .slide-body.light { color: var(--sand); }
  .ornament {
    width:4vmin; height:0.2vmin;
    background: var(--terracotta);
    margin: 20px 0;
  }

  /* Stat callouts */
  .stat-row {
    display:flex; gap: 3.5vmin;
    margin-top: 2.5vmin;
    flex-wrap:wrap;
  }
  .stat-item { display:flex; flex-direction:column; gap:0.4vmin; }
  .stat-num {
    font-family:'Playfair Display', serif;
    font-size:clamp(1.8rem,2.5vw,3rem);
    color: var(--terracotta);
    font-weight:700;
  }
  .stat-desc {
    font-family:'Lora', serif;
    font-size:clamp(0.8rem,1vw,1.1rem);
    color: var(--brown);
    max-width:200px;
    line-height:1.4;
  }

  /* Character intro cards */
  .character-strip {
    display:flex; gap:40px;
    justify-content:center;
    margin-top:3vmin;
  }
  .char-card {
    display:flex; flex-direction:column;
    align-items:center; gap:1vmin;
    max-width:180px; text-align:center;
  }
  .char-avatar {
    width:14vmin; height:14vmin;
    border-radius:50%;
    background: linear-gradient(135deg, #7ab0aa 0%, #2e6460 100%);
    display:flex; align-items:center; justify-content:center;
    font-size:clamp(2rem,3vw,3.5rem);
    border: 0.3vmin solid var(--terracotta);
  }
  .char-name {
    font-family:'Playfair Display', serif;
    font-size:clamp(1.2rem,1.8vw,2rem);
    color: var(--charcoal);
  }
  .char-role {
    font-family:'Lora', serif;
    font-size:clamp(0.85rem,1.1vw,1.3rem);
    color: var(--rust);
    letter-spacing:0.06em;
  }

  /* ── PROGRESS BAR ── */
  #progress-bar {
    position:fixed;
    bottom:0; left:0;
    height:0.4vmin;
    background: var(--terracotta);
    width:0%;
    z-index:100;
    transition: width linear;
  }

  /* ── SLIDE COUNTER ── */
  #slide-counter {
    position:fixed;
    bottom:1.5vmin; left:50%;
    transform:translateX(-50%);
    display:flex; gap:0.7vmin;
    z-index:100;
  }
  .dot {
    width:0.7vmin; height:0.7vmin;
    border-radius:50%;
    background: rgba(255,255,255,0.25);
    transition: background 0.3s, transform 0.3s;
  }
  .dot.current {
    background: var(--terracotta);
    transform:scale(1.35);
  }

  /* Map slide special layout */
  .slide-map {
    background: var(--charcoal);
    display:grid;
    grid-template-columns: 1.6fr 0.4fr;
    height: 100vh;
    overflow: hidden;
  }
  .slide-map .map-visual {
    display:flex; align-items:center; justify-content:center;
    padding: 1.5vmin 1vmin 1.5vmin 2vmin;
    background: var(--charcoal);
    overflow:hidden;
    min-height: 0;
  }
  .slide-map .map-visual img {
    max-width:100%;
    max-height: 97vh;
    width: auto;
    height: auto;
    object-fit:contain;
    display: block;
  }
  .slide-map .map-text {
    display:flex; flex-direction:column;
    justify-content:center;
    padding: 3vmin 3vmin 3vmin 2vmin;
    background: var(--charcoal);
    gap: 0;
    overflow: hidden;
    min-height: 0;
  }
  .slide-map .map-footnote {
    margin-top: 1.5vmin;
    padding-top: 1.2vmin;
    border-top: 1px solid rgba(255,255,255,0.1);
    font-family:'Lora', serif;
    font-size: clamp(0.6rem, 0.75vw, 0.9rem);
    color: rgba(232,220,200,0.7);
    line-height: 1.5;
    letter-spacing: 0.03em;
  }

  /* World/India placeholder slides */
  .slide-placeholder-map {
    background: var(--cream);
    display:grid;
    grid-template-columns: 1.1fr 0.9fr;
  }
  .slide-placeholder-map .map-area {
    position:relative;
    overflow:hidden;
  }
  .slide-placeholder-map .text-area {
    display:flex; flex-direction:column;
    justify-content:center;
    padding: 5vmin 4vmin;
    background: var(--charcoal);
  }

  /* Conclusion */
  .slide-conclusion {
    background: var(--charcoal);
    display:grid;
    grid-template-columns: 1fr 1fr;
  }
  .slide-conclusion .left {
    display:flex; flex-direction:column;
    justify-content:center;
    padding: 5vmin 4vmin;
  }
  .slide-conclusion .right {
    display:flex; flex-direction:column;
    justify-content:center;
    padding: 5vmin 4vmin;
    border-left: 1px solid rgba(255,255,255,0.1);
    gap:2.5vmin;
  }
  .policy-item {
    display:flex; gap:1.4vmin; align-items:flex-start;
  }
  .policy-dot {
    width:0.8vmin; height:0.8vmin;
    min-width:0.8vmin;
    border-radius:50%;
    background: var(--terracotta);
    margin-top:0.6vmin;
  }
  .policy-text {
    font-family:'Lora', serif;
    font-size:clamp(1rem,1.4vw,1.6rem);
    color: var(--sand);
    line-height:1.6;
  }

  /* QR placeholder */
  .qr-box {
    width:9vmin; height:9vmin;
    border:2px solid var(--ochre);
    display:flex; align-items:center; justify-content:center;
    flex-direction:column; gap:0.5vmin;
    padding:1vmin;
  }
  .qr-box .qr-inner {
    width:100%; height:100%;
    background: repeating-linear-gradient(
      0deg, var(--ochre) 0px, var(--ochre) 2px, transparent 2px, transparent 6px
    ),
    repeating-linear-gradient(
      90deg, var(--ochre) 0px, var(--ochre) 2px, transparent 2px, transparent 6px
    );
    opacity:0.3;
  }

  /* ── RESPONSIVE OVERRIDES (tablet) ── */
  @media (max-width: 768px) {
    .slide-split { grid-template-columns: 1fr; }
    .slide-map { grid-template-columns: 1fr; }
    .slide-conclusion { grid-template-columns: 1fr; }
    .slide-placeholder-map { grid-template-columns: 1fr; }
  }

  /* ══════════════════════════════════════════════════════
     MOBILE PHONE OVERRIDES (portrait & narrow landscape)
     Every two/multi-column layout collapses to a single
     column so nothing is squeezed onto a narrow screen.
     !important is required because most layouts are set
     via inline styles in the markup.
  ══════════════════════════════════════════════════════ */
  @media (max-width: 700px) {

    html, body {
      font-size: clamp(13px, 3.4vw, 20px);
    }

    /* Any slide using the "text | image, 1fr 1.6fr" grid pattern
       (character transitions + field photo slides) stacks to
       one column: image on top, caption below. */
    .slide-char-transition,
    .slide-field-photo,
    #slideshow > .slide[style*="grid-template-columns:1fr 1.6fr"] {
      grid-template-columns: 1fr !important;
      grid-template-rows: 55vh 45vh !important;
      height: 100vh !important;
    }
    .slide-char-transition > div,
    .slide-field-photo > div {
      padding: 3vh 5vw !important;
      min-height: 0;
      overflow: hidden;
    }
    .slide-char-transition > div:first-child,
    .slide-field-photo > div:first-child { order: 2 !important; }
    .slide-char-transition > div:last-child,
    .slide-field-photo > div:last-child  { order: 1 !important; }

    /* Standard split / map / conclusion / placeholder-map layouts */
    .slide-split,
    .slide-map,
    .slide-conclusion,
    .slide-placeholder-map {
      grid-template-columns: 1fr !important;
      grid-template-rows: 48vh 52vh;
    }
    .slide-map .map-visual { padding: 1vh 3vw !important; }
    .slide-map .map-text   { padding: 2vh 4vw !important; }
    .slide-conclusion .left,
    .slide-conclusion .right,
    .slide-split .left {
      padding: 2.5vh 4vw !important;
    }
    .slide-conclusion .right {
      border-left: none !important;
      border-top: 1px solid rgba(255,255,255,0.1);
    }

    /* World map country grid: 6 cols -> 3 cols */
    .mobile-world-grid {
      grid-template-columns: repeat(3, 1fr) !important;
    }

    /* Credits: 2 cols -> 1 col */
    .mobile-credits-grid {
      grid-template-columns: 1fr !important;
      gap: 24px !important;
    }
    .mobile-credits-grid > div[style*="grid-column"] {
      grid-column: auto !important;
    }

    /* Comic-frame slides: give the sentence bar and stat bar
       more breathing room relative to portrait height instead
       of the kiosk-tuned vmin values. */
    .frame-label { flex-basis: 16vh !important; }
    .stat-bar    { flex-basis: 20vh !important; }
    .frame-label .frame-sentence { padding: 2vh 4vw !important; }
    .stat-bar { padding: 1.5vh 4vw !important; }

    /* Title slide padding */
    .slide-title { padding: 6vh 6vw !important; }

    /* Text-only slides */
    .slide-text { padding: 4vh 6vw !important; }

    /* Character strip (three portraits) wraps instead of
       squeezing onto one line */
    .character-strip { gap: 16px !important; flex-wrap: wrap; }
    .char-card { max-width: 110px; }

    /* Stat rows wrap cleanly */
    .stat-row { gap: 20px !important; }

    /* Slide counter dots: slightly larger tap/visual target */
    .dot { width: 6px; height: 6px; }
  }

  /* Landscape phones (wide but short) keep more of the
     original side-by-side layouts, since width is plentiful,
     but still relax the comic-frame chrome sizing. */
  @media (max-width: 900px) and (max-height: 500px) and (orientation: landscape) {
    .frame-label { flex-basis: 22vh !important; }
    .stat-bar    { flex-basis: 26vh !important; }
  }


</style>
</head>
<body>

<div id="slideshow">

  <!-- ══════════════════════════════════════════
       SLIDE 1 — TITLE
  ══════════════════════════════════════════ -->
  <div class="slide slide-title active" data-duration="8">
    <div class="eyebrow">London School of Economics and Political Science · British Academy Ideas Festival 2026</div>
    <h1>Street Vendors: <em>Smarter Choices,</em> Tougher Lives Than You'd Think</h1>
    <div class="title-ornament"></div>
    <div class="subtitle">Muskan Jain &nbsp;·&nbsp; Lachi Singh</div>
  </div>

  <!-- ══════════════════════════════════════════
       SLIDE 2 — WORLD MAP / COUNTRY SILHOUETTES
  ══════════════════════════════════════════ -->
  <div class="slide slide-text" data-duration="16" style="background:var(--charcoal); display:flex; flex-direction:column; align-items:center; justify-content:center; padding:3vmin 5vmin 2.5vmin;">
    <div style="text-align:center; margin-bottom:1.5vmin;">
      <div class="slide-tag" style="color:var(--ochre); text-align:center;">Global Context</div>
      <div class="slide-headline light" style="font-size:clamp(1.6rem,3vw,3.5rem); margin-bottom:1vmin;">A large number of people work as street vendors across the world</div>
      <p class="slide-body light" style="font-size:clamp(0.85rem,1.3vw,1.4rem); max-width:1000px; margin:0 auto;">Depending on where you focus, street vending makes up anywhere from 1.8% to 8% of employment in developing countries.</p>
    </div>

    <!-- Country silhouettes grid -->
    <style is:inline>
      .country-block { display:flex; flex-direction:column; align-items:center; justify-content:flex-end; gap:0.5vmin; }
      .country-svg { display:block; width:auto; height:auto; max-height:9vmin; max-width:100%; }
      .country-name { font-family:'Lora',serif; font-size:clamp(0.6rem,0.85vw,0.95rem); color:var(--cream); text-align:center; letter-spacing:0.04em; }
      .country-pct { font-family:'Playfair Display',serif; font-size:clamp(0.75rem,1.1vw,1.2rem); font-weight:700; }
    </style>
    <div class="mobile-world-grid" style="display:grid; grid-template-columns:repeat(6,1fr); gap:1.5vmin 2vmin; width:100%; max-width:1300px;">

      <!-- Each country: SVG silhouette + name + % -->
      <!-- Using simplified geometric shapes as stand-in silhouettes, filled by share -->
      <!-- Color scale: light teal (#a8d5cf) at 1.8% → deep terracotta (#b06a2a) at 8% -->

      <div class="country-block">
        <svg class="country-svg" viewBox="0 0 110 55">
          <path d="M 105.9,37.4 L 103.3,38.3 L 101.4,36.9 L 95.0,36.2 L 92.7,37.0 L 86.5,37.9 L 83.6,37.8 L 77.3,39.8 L 72.8,39.8 L 70.0,38.8 L 64.0,40.3 L 62.2,39.3 L 61.9,42.3 L 60.4,43.5 L 59.0,44.7 L 57.0,42.2 L 59.0,40.2 L 55.7,40.6 L 51.2,39.4 L 47.4,42.5 L 39.2,43.1 L 34.8,40.2 L 28.9,40.0 L 27.7,42.3 L 23.9,42.9 L 18.6,40.0 L 12.7,40.1 L 9.5,34.7 L 5.5,31.7 L 8.1,27.5 L 4.7,24.9 L 10.7,19.7 L 19.1,19.5 L 21.4,15.3 L 31.8,16.0 L 38.3,12.5 L 44.6,11.0 L 53.6,10.9 L 63.1,14.7 L 70.9,16.8 L 77.3,16.0 L 82.0,16.4 L 88.4,13.6 L 94.2,13.3 L 99.4,16.0 L 100.3,17.9 L 99.8,20.6 L 103.9,21.9 L 106.0,23.5 L 102.3,25.1 L 104.0,31.3 L 102.9,33.0 L 105.9,37.4 L 105.9,37.4 Z M 4.4,12.0 L 9.9,10.3 L 14.6,11.0 L 15.3,13.1 L 20.0,14.9 L 19.0,16.2 L 12.6,16.5 L 10.3,18.2 L 5.7,21.1 L 4.0,18.6 L 4.1,17.5 L 5.4,16.9 L 7.1,13.5 L 4.4,12.0 Z" fill="rgb(168,213,207)" stroke="rgba(255,255,255,0.2)" stroke-width="0.8"/>
        </svg>
        <div class="country-name">Turkey</div>
        <div class="country-pct" style="color:rgb(168,213,207);">1.8%</div>
      </div>
