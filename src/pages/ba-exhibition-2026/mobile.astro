<!-- Progress bar & dots -->
<div id="progress-bar"></div>
<div id="slide-counter"></div>

<script is:inline>

// ── SLIDESHOW ENGINE ──
const slides      = Array.from(document.querySelectorAll('#slideshow > .slide'));
const progressBar = document.getElementById('progress-bar');
const counter     = document.getElementById('slide-counter');
let current       = 0;
let timer         = null;
let progressTimer = null;
let inactivityTimer = null;
let isInteracting = false;
const INACTIVITY_RESUME = 5000; // resume after 20s no touch

// Build dots
slides.forEach((_, i) => {
  const d = document.createElement('div');
  d.className = 'dot' + (i === 0 ? ' current' : '');
  counter.appendChild(d);
});

function getDuration(slide) {
  return parseInt(slide.dataset.duration || '10') * 1000;
}


function goTo(index, skipAnimation) {
  slides[current].classList.remove('active');
  counter.children[current].classList.remove('current');
  current = (index + slides.length) % slides.length;
  slides[current].classList.add('active');
  counter.children[current].classList.add('current');
  startProgress(getDuration(slides[current]));
}

function startProgress(duration) {
  clearInterval(progressTimer);
  clearTimeout(timer);
  progressBar.style.transition = 'none';
  progressBar.style.width = '0%';
  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      progressBar.style.transition = `width ${duration}ms linear`;
      progressBar.style.width = '100%';
    });
  });
  timer = setTimeout(() => {
    if (!isInteracting) goTo(current + 1);
  }, duration);
}

function pauseAutoplay() {
  isInteracting = true;
  clearTimeout(timer);
  clearInterval(progressTimer);
  progressBar.style.transition = 'none';
  clearTimeout(inactivityTimer);
  inactivityTimer = setTimeout(resumeAutoplay, INACTIVITY_RESUME);
}

function resumeAutoplay() {
  isInteracting = false;
  startProgress(getDuration(slides[current]));
}


// Touch/click on slide advances it (if no caption open)
// ── SWIPE NAVIGATION ──
let touchStartX = null;
let touchStartY = null;
const SWIPE_THRESHOLD = 50;

document.getElementById('slideshow').addEventListener('touchstart', function(e) {
  touchStartX = e.touches[0].clientX;
  touchStartY = e.touches[0].clientY;
}, { passive: true });

document.getElementById('slideshow').addEventListener('touchend', function(e) {
  if (touchStartX === null) return;
  const dx = e.changedTouches[0].clientX - touchStartX;
  const dy = e.changedTouches[0].clientY - touchStartY;
  // Only register as swipe if horizontal movement dominates
  if (Math.abs(dx) < SWIPE_THRESHOLD || Math.abs(dx) < Math.abs(dy)) return;
  pauseAutoplay();
  if (dx < 0) {
    goTo(current + 1); // swipe left → next
  } else {
    goTo(current - 1); // swipe right → previous
  }
  touchStartX = null;
  touchStartY = null;
  clearTimeout(inactivityTimer);
  inactivityTimer = setTimeout(resumeAutoplay, INACTIVITY_RESUME);
});

// Also keep click for non-touch screens (left half = back, right half = forward)
document.getElementById('slideshow').addEventListener('click', function(e) {
  pauseAutoplay();
  if (e.clientX < window.innerWidth / 2) {
    goTo(current - 1); // left half → previous
  } else {
    goTo(current + 1); // right half → next
  }
  clearTimeout(inactivityTimer);
  inactivityTimer = setTimeout(resumeAutoplay, INACTIVITY_RESUME);
});

// Kick off
startProgress(getDuration(slides[current]));
</script>
</body>
</html>
